# Empty = same-origin: fetch '/api/v1/...' against the Spring Boot host.
# Override only when the API is on a different origin (CORS required server-side).
# Must NOT include a trailing slash. Examples:
#   VITE_API_BASE_URL=http://localhost:8080
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=
